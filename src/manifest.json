{
    "manifest_version" : 3,
    "name" : "Prompt Optimizer Hackathon",
    "version" : "1.0",
    "permissions" : ["storage", "activeTab"],
    "content_scripts" : [
        {
            "matches" : ["https://chatgpt.com/*"],
            "js" : ["content.js"]
        }
    ],
    "action" : {
        "default_popup" : "popup/popup.html"
    }






}